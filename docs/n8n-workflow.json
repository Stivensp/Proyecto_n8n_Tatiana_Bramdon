    {
      "parameters": {
        "jsCode": "const current = $json.current;\n\nconst temperature = current.temperature_2m;\nconst humidity = current.relative_humidity_2m;\nconst code = current.weather_code;\n\nconst city = $items(\"Extract Coordinates1\")[0].json.city;\n\nlet condition = \"Desconocido\";\nlet recommendation = \"\";\n\nif (code === 0) {\n  condition = \"Cielo despejado\";\n  recommendation = \"Buen día para ropa ligera.\";\n}\n\nelse if (code >= 1 && code <= 3) {\n  condition = \"Parcialmente nublado\";\n  recommendation = \"Podrías llevar una chaqueta ligera.\";\n}\n\nelse if (code >= 45 && code <= 48) {\n  condition = \"Niebla\";\n  recommendation = \"Lleva abrigo y conduce con cuidado.\";\n}\n\nelse if (code >= 51 && code <= 67) {\n  condition = \"Lluvia ligera\";\n  recommendation = \"Lleva paraguas o impermeable.\";\n}\n\nelse if (code >= 71 && code <= 77) {\n  condition = \"Nieve\";\n  recommendation = \"Usa ropa térmica.\";\n}\n\nelse if (code >= 80 && code <= 82) {\n  condition = \"Chubascos\";\n  recommendation = \"Podría llover, lleva paraguas.\";\n}\n\nelse if (code >= 95) {\n  condition = \"Tormenta eléctrica\";\n  recommendation = \"Evita salir si no es necesario y si sales lleva impermeable.\";\n}\n\nreturn [\n  {\n    json: {\n      city: city,\n      temperature: temperature,\n      condition: condition,\n      recommendation: recommendation\n    }\n  }\n];"
      },
