      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        -80,
        200
      ]
    },
    {
      "parameters": {
        "jsCode": "const city = $items(\"Geocoding\")[0].json.results?.[0]?.name || $json.city;\nconst temperature = $items(\"Weather\")[0].json.current?.temperature_2m;\nconst weatherCode = $items(\"Weather\")[0].json.current?.weather_code;\n\nfunction mapWeatherCode(code) {\n  if (code === 0) return \"despejado\";\n  if (code >= 1 && code <= 3) return \"parcialmente nublado\";\n  if (code === 45 || code === 48) return \"niebla\";\n  if (code >= 51 && code <= 57) return \"llovizna\";\n  if (code >= 61 && code <= 67) return \"lluvia\";\n  if (code >= 71 && code <= 77) return \"nieve\";\n  if (code >= 80 && code <= 82) return \"chubascos\";\n  if (code >= 85 && code <= 86) return \"nevadas\";\n  if (code >= 95 && code <= 99) return \"tormenta\";\n  return \"condicion desconocida\";\n}\n\nconst condition = mapWeatherCode(weatherCode);\nlet recommendation = \"\";\nif (temperature < 10) {\n  recommendation = \"abrigo grueso\";\n} else if (temperature >= 10 && temperature <= 17) {\n  recommendation = \"chaqueta ligera\";\n} else if (temperature >= 18 && temperature <= 25) {\n  recommendation = \"ropa comoda\";\n} else {\n  recommendation = \"ropa ligera\";\n}\n\nif ((condition || \"\").toLowerCase().includes(\"lluvia\")) {\n  recommendation += \" y paraguas\";\n}\n\nreturn [{ json: { city, temperature, condition, recommendation } }];"
      },
