    {
      "parameters": {
        "jsCode": "const current = $json.current;\n\nconst temperature = current.temperature_2m;\nconst humidity = current.relative_humidity_2m;\nconst wind = current.wind_speed_10m;\nconst feelsLike = current.apparent_temperature;\nconst code = current.weather_code;\n\nconst city = $items(\"Extraer coordenadas\")[0].json.city;\n\nlet condition = \"Desconocido\";\nlet recommendation = \"\";\n\n// Condición del clima\nif (code === 0) {\n  condition = \"Cielo despejado\";\n}\nelse if (code >= 1 && code <= 3) {\n  condition = \"Parcialmente nublado\";\n}\nelse if (code >= 45 && code <= 48) {\n  condition = \"Niebla\";\n}\nelse if (code >= 51 && code <= 67) {\n  condition = \"Lluvia ligera\";\n}\nelse if (code >= 71 && code <= 77) {\n  condition = \"Nieve\";\n}\nelse if (code >= 80 && code <= 82) {\n  condition = \"Chubascos\";\n}\nelse if (code >= 95) {\n  condition = \"Tormenta eléctrica\";\n}\n\n// Recomendación basada en sensación térmica\nif (feelsLike >= 30) {\n  recommendation = \"Hace bastante calor. Usa ropa ligera y mantente hidratado.\";\n}\nelse if (feelsLike >= 24) {\n  recommendation = \"Clima cálido. Ropa fresca es recomendable.\";\n}\nelse if (feelsLike >= 18) {\n  recommendation = \"Temperatura agradable.\";\n}\nelse {\n  recommendation = \"Podrías necesitar una chaqueta ligera.\";\n}\n\n// Ajuste si llueve\nif (code >= 51 && code <= 82) {\n  recommendation += \" También es recomendable llevar paraguas.\";\n}\n\nreturn [\n  {\n    json: {\n      city: city,\n      temperature: temperature,\n      humidity: humidity,\n      wind: wind,\n      feels_like: feelsLike,\n      condition: condition,\n      recommendation: recommendation\n    }\n  }\n];"
      },
